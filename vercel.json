{
  "version": 2,
  "builds": [
    {
      "src": "aurora-node/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "aurora-vue/aurora-blog",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "aurora-node/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "aurora-vue/aurora-blog/dist/index.html"
    }
  ]
}